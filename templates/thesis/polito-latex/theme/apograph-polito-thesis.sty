\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{theme/apograph-polito-thesis}[2026/07/18 v0.2.0 faithful PoliTo thesis packaging]

% Shared Apograph modules replace duplicated low-level package declarations;
% the remaining packages and configuration preserve the upstream feature set.
\PassOptionsToPackage{final}{microtype}
\RequirePackage{apograph-math}
\RequirePackage{apograph-typography}
\RequirePackage{apograph-colors}

\RequirePackage[english,italian]{babel}
\RequirePackage{lmodern}
\RequirePackage{hyperref}
\RequirePackage[
  hyperref=true,
  backref=true,
  backend=biber,
  maxbibnames=9,
  maxcitenames=2,
  style=numeric,
  citestyle=numeric,
  sorting=none
]{biblatex}
\RequirePackage{adjustbox}
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}
\RequirePackage{booktabs}
\RequirePackage[labelfont=bf]{caption}
\RequirePackage{csquotes}
\RequirePackage{enumitem}
\RequirePackage{etoolbox}
\RequirePackage{geometry}
\RequirePackage[toc,abbreviations,nonumberlist]{glossaries-extra}
\RequirePackage{graphicx}
\RequirePackage{listings}
\RequirePackage{lipsum}
\RequirePackage{makecell}
\RequirePackage{mfirstuc}
\RequirePackage{multirow}
\RequirePackage{nicefrac}
\RequirePackage{ragged2e}
\RequirePackage{siunitx}
\RequirePackage{subfig}
\RequirePackage{svg}
\RequirePackage{tabularx}
\RequirePackage{textcomp}
\RequirePackage{url}
\RequirePackage{verbatim}

\setabbreviationstyle{long-short-desc}

\hypersetup{
  pdfpagemode={UseOutlines},
  bookmarksopen,
  pdfstartview={FitH},
  colorlinks,
  linkcolor={black},
  citecolor={black},
  urlcolor={black}
}

\svgsetup{
  inkscapeformat=pdf,
  inkscapelatex=false
}

\sisetup{
  detect-all,
  mode=text,
  group-separator={,},
  group-minimum-digits=3
}

\setcounter{biburlnumpenalty}{9000}
\setcounter{biburllcpenalty}{9000}
\setcounter{biburlucpenalty}{9000}

\definecolor{rulecolor}{rgb}{0,0,0}
\definecolor{commentcolor}{rgb}{0,0.6,0}
\definecolor{linenumbercolor}{rgb}{0.5,0.5,0.5}
\definecolor{keywordcolor}{rgb}{0,0,0.95}
\definecolor{backcolor}{rgb}{1,1,1}
\definecolor{stringcolor}{rgb}{0.58,0,0.82}

\lstdefinelanguage{JavaScript}{
  keywords={break,case,catch,continue,debugger,default,delete,do,else,finally,for,function,if,in,instanceof,new,return,switch,this,throw,try,typeof,var,void,while,with,const,import,async,await},
  morecomment=[l]{//},
  morecomment=[s]{/*}{*/},
  morestring=[b]',
  morestring=[b]",
  sensitive=true
}

\lstset{
  language=JavaScript,
  backgroundcolor=\color{backcolor},
  basicstyle=\footnotesize,
  breakatwhitespace=false,
  breaklines=true,
  captionpos=t,
  commentstyle=\color{commentcolor},
  extendedchars=true,
  frame=single,
  keepspaces=true,
  keywordstyle=\color{keywordcolor},
  numbers=left,
  numbersep=5pt,
  numberstyle=\tiny\color{linenumbercolor},
  rulecolor=\color{rulecolor},
  showspaces=false,
  showstringspaces=false,
  showtabs=false,
  stepnumber=1,
  stringstyle=\color{stringcolor},
  tabsize=4,
  title=\lstname,
  inputencoding=utf8,
