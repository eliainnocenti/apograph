}

\algnewcommand{\LineComment}[1]{\State \(\triangleright\) #1}

\DeclarePairedDelimiter\abs{\lvert}{\rvert}
\DeclarePairedDelimiter\norm{\lVert}{\rVert}
\makeatletter
\let\apograph@oldabs\abs
\def\abs{\@ifstar{\apograph@oldabs}{\apograph@oldabs*}}
\let\apograph@oldnorm\norm
\def\norm{\@ifstar{\apograph@oldnorm}{\apograph@oldnorm*}}
\makeatother

\addto\captionsenglish{\renewcommand{\contentsname}{Table of Contents}}

% These are the upstream title-page font definitions, preserved verbatim apart
% from namespacing the command names.
\newcommand{\apographInstitutionFont}{\fontsize{20}{30}\scshape}
\newcommand{\apographDivisionFont}{\fontsize{12}{20}\rmfamily}
\newcommand{\apographTitleFont}{\fontsize{24}{28}\scshape}
\newcommand{\apographSubtitleFont}{\fontsize{14}{28}\scshape}
\newcommand{\apographFixedNamesFont}{\fontsize{12}{16}\mdseries}
\newcommand{\apographNamesFont}{\fontsize{12}{16}\mdseries}

% A person occupies one row of the surrounding title-page table. Keeping the
% row structure identical to the upstream template also keeps its vertical
% stretch calculations identical, regardless of how many people are listed.
\newcommand{\apographPerson}[1]{& \apographNamesFont #1 \\}

\newcommand{\apographGraduationSessionLabel}{%
  \iflanguage{english}{Graduation Session}{Sessione di laurea}%
}

% The authorized user-provided file has the same format and 110 mm width as the
% image used by the upstream template. The fallback preserves its occupied area
% so all following title-page proportions remain stable.
\newcommand{\apographPoliToLogo}{%
  \IfFileExists{theme/assets/polito-logo.jpg}{%
    \includegraphics[width=110mm]{theme/assets/polito-logo.jpg}%
  }{%
    \fbox{%
      \parbox[c][40.5mm][c]{108mm}{%
        \centering\sffamily
        {\Large\bfseries Politecnico di Torino\par}
        \vspace{2mm}
        {\small Optional user-provided logo omitted\par}
      }%
    }%
  }%
}

\newcommand{\apographPoliToTitlePage}{%
  \newgeometry{top=4cm,left=3cm,right=3cm,bottom=4cm,heightrounded}%
  \begin{titlepage}
  \centering
  %
  \apographPoliToLogo\\
  %
  \vspace{\stretch{2}}
  %
  {\apographInstitutionFont \textbf{\apographUniversity} \par}
  %
  \vspace{\stretch{1}}
  %
  {\apographDivisionFont \apographDegreeProgramme \par}
  {\apographDivisionFont \apographAcademicYear \par}
  \iflanguage{english}{%
    {\apographDivisionFont Graduation Session \apographGraduationSession \par}%
  }{%
    {\apographDivisionFont Sessione di laurea \apographGraduationSession \par}%
  }%
  %
  \vspace{\stretch{4}}
  %
  {\apographTitleFont \textbf{\apographThesisTitle} \par}
  {\apographSubtitleFont \textbf{\apographThesisSubtitle} \par}
  %
  \vspace{\stretch{4}}
  %
  % The upstream load order leaves a 20 pt strut active here (14 pt high and
  % 6 pt deep). Make that metric explicit and local so consolidating the
  % packages cannot compress the supervisor and candidate rows.
  \begingroup
  \setbox\strutbox=\hbox{\vrule height 14pt depth 6pt width 0pt}%
  \makebox[\textwidth]{\null\hfill\def\arraystretch{1.1}%
    \begin{minipage}[t]{.4\textwidth}
      \begin{tabular}[t]{@{}ll@{}}
        \apographFixedNamesFont \apographSupervisorsLabel: & \\
        \apographSupervisors
      \end{tabular}
      \ifdefempty{\apographCosupervisors}{}{%
        \par\vspace{1.5ex}%
        \begin{tabular}[t]{@{}ll@{}}
          \apographFixedNamesFont \apographCosupervisorsLabel: & \\
          \apographCosupervisors
        \end{tabular}%
      }%
    \end{minipage}
    %
    \hfill
    %
    \begin{minipage}[t]{.4\textwidth}
      \begin{tabular}[t]{@{}ll@{}}
        \apographFixedNamesFont \apographCandidatesLabel: & \\
        \apographCandidates
      \end{tabular}
    \end{minipage}\hfill\null}%
  \endgroup\\
  %
  \vspace{\stretch{1}}
  %
  \end{titlepage}
  \restoregeometry
}

\endinput
