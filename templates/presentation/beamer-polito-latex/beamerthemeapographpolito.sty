\ProvidesPackage{beamerthemeapographpolito}[2026/07/18 v0.3.0 unofficial PoliTo Beamer theme]

\RequirePackage{etoolbox}
\RequirePackage{tikz}

% Optional behavior is explicit so the minimal starter stays quiet.
\newtoggle{apograph@sectionpages}
\newtoggle{apograph@slidenumbers}
\newtoggle{apograph@autoframesubtitles}
\togglefalse{apograph@sectionpages}
\toggletrue{apograph@slidenumbers}
\togglefalse{apograph@autoframesubtitles}
\DeclareOptionBeamer{sectionpages}{\toggletrue{apograph@sectionpages}}
\DeclareOptionBeamer{noslidenumbers}{\togglefalse{apograph@slidenumbers}}
\DeclareOptionBeamer{autoframesubtitles}{\toggletrue{apograph@autoframesubtitles}}
\ProcessOptionsBeamer

% Caladea is a Cambria clone, Carlito a Calibri clone
\RequirePackage{caladea,carlito}
\renewcommand{\familydefault}{\sfdefault}

\RequirePackage{graphicx,apograph-polito-colors}

% No navigation symbols
\setbeamertemplate{navigation symbols}{}

\newcommand{\@footlineauthor}{\insertauthor \enspace$\vert$\enspace}
\newcommand{\@footlinepayoff}{\@footlineauthor\inserttitle}
\newcommand{\apographFootlineText}[1]{\renewcommand{\@footlinepayoff}{#1}}
% Define footline content
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\textwidth,ht=5mm,dp=3mm,rightskip=1cm,leftskip=1cm]{footline}
  \iftoggle{apograph@slidenumbers}{\insertframenumber/\inserttotalframenumber}{}
  \ifstrempty{\@footlinepayoff}{}{%
    \usebeamerfont{footline}\hfill\@footlinepayoff
  }
  \end{beamercolorbox}
}

% Set footline AND coordinate blocks with it
\newcommand{\apographFootlineColor}[1]{% empty means transparent
  \ifstrempty{#1}{%
    \apographFootlineText{}
    \setbeamercolor{footline}{fg=darkgray, bg=}
    \setbeamercolor{block title}{fg=white,bg=maincolor}
    \setbeamercolor{block body}{fg=white,bg=maincolor}
  }{
    \apographFootlineText{\@footlineauthor\inserttitle}
    \setbeamercolor{footline}{fg=white,bg=#1}
    \setbeamercolor{block title}{fg=white,bg=#1}
    \setbeamercolor{block body}{fg=white,bg=#1}
  }%
}
\apographFootlineColor{} % Default: no footline

\IfFileExists{theme/assets/logo_RGB.png}{%
  \pgfdeclareimage[width=0.09\paperwidth]{logo}{theme/assets/logo_RGB}%
}{}
\IfFileExists{theme/assets/Logo_RGB_negative.png}{%
  \pgfdeclareimage[width=0.09\paperwidth]{whitelogo}{theme/assets/Logo_RGB_negative}%
}{}
\newcommand{\@logo}{logo}

% Set colours
% NOTE! Beamer colors should be set in the preamble. It often works fine in the 
%       document itself, but NOT for normal text foreground.
%       \apographThemeColor should only be called from the preamble.
\newcommand{\apographThemeColor}[1]{%
	\ifstrequal{#1}{main}{%
        \setbeamercolor{footline}{fg=white}
		\setbeamercolor{normal text}{fg=white,bg=maincolor}
		\setbeamercolor{structure}{fg=white}
		\renewcommand{\@logo}{whitelogo}
		\setbeamercolor{block title}{fg=maincolor,bg=sintefgrey}
		\setbeamercolor{block body}{fg=darkgray,bg=sintefgrey}
	}{\ifstrequal{#1}{white}{%
        \setbeamercolor{footline}{fg=darkgray}
		\setbeamercolor{normal text}{fg=darkgray,bg=white}
		\setbeamercolor{structure}{fg=maincolor}
		\renewcommand{\@logo}{logo}
		\setbeamercolor{block title}{fg=white,bg=maincolor}
		\setbeamercolor{block body}{fg=darkgray,bg=sintefgrey}
	}{%
      \PackageError{beamerthemeapographpolito}{Unknown color mode '#1'}{Use 'white' or 'main'.}%
    }}%
}
\apographThemeColor{white} % Default: white theme

\setbeamercolor{title}{fg=maincolor,bg=white}
\setbeamercolor{alerted text}{fg=sintefred}
\setbeamercolor{author}{fg=black}
\setbeamercolor{date}{fg=black}

\setbeamerfont{author}{size=\scriptsize}
\setbeamerfont{date}{size=\tiny}
\setbeamerfont{title}{series=\bfseries}
\setbeamerfont{subtitle}{series=\mdseries,size=\footnotesize}
\setbeamerfont{frametitle}{series=\bfseries}
\setbeamerfont{framesubtitle}{series=\mdseries}
\setbeamerfont{footline}{size=\scriptsize}
\setbeamerfont{block title}{series=\centering\bfseries}

% Code to get prettier boxes
\setbeamertemplate{blocks}[rounded]

% Bullets in several levels
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{\textemdash}
\setbeamertemplate{itemize subsubitem}{\ensuremath{\circ}}

\newenvironment{apographcolorblock}[3][white]{%
	\begingroup
	\setbeamercolor{block title}{fg=#1,bg=#2}
	\setbeamercolor{block body} {fg=#1,bg=#2}
	\begin{block}{#3}
	}{%
	\end{block}
	\endgroup
}

% Put the logo in each slide's top left area (with fallback if logo files are missing)
\setbeamertemplate{headline}{%
  \hspace{0.06\textwidth}%
  \ifdefstring{\@logo}{logo}{%
    \IfFileExists{theme/assets/logo_RGB.png}{%
      \pgfuseimage{logo}%
    }{%
      \tikz[baseline=(char.base)]{
        \node[draw=maincolor, fill=sintefgrey, rounded corners=1pt,
          minimum width=0.09\paperwidth, minimum height=0.08\paperheight,
          inner sep=2.4pt, font=\tiny\sffamily\bfseries\color{maincolor}]
          (char) {PoliTo};
      }%
    }%
  }{%
    \IfFileExists{theme/assets/Logo_RGB_negative.png}{%
      \pgfuseimage{whitelogo}%
    }{%
      \tikz[baseline=(char.base)]{
        \node[draw=white, fill=maincolor, rounded corners=1pt,
          minimum width=0.09\paperwidth, minimum height=0.08\paperheight,
          inner sep=2.4pt, font=\tiny\sffamily\bfseries\color{white}]
          (char) {PoliTo};
      }%
    }%
  }%
}

% Define frame title and subtitle layout
\setbeamertemplate{frametitle}{%
  \vspace*{-3.5ex}
  \begin{beamercolorbox}[leftskip=2cm]{frametitle}%
    \usebeamerfont{frametitle}\insertframetitle\\
    \usebeamerfont{framesubtitle}\insertframesubtitle
  \end{beamercolorbox}
}

\def\@courseLabel{}
\def\@IDnumber{}
\def\@email{}

\newcommand{\apographCourse}[1]{\def\@courseLabel{#1}}
\newcommand{\apographStudentID}[1]{\def\@IDnumber{#1}}
\newcommand{\apographEmail}[1]{\def\@email{#1}}

% Define the title page
\setbeamertemplate{title page}{%
  \vskip0pt plus 1filll%
  % Reposition the box in an inelegant way - but it works!
  \hspace{-12mm}
  \vspace{20mm}
  %\begin{beamercolorbox}[wd=0.72\textwidth,sep=10pt,leftskip=8mm]{title}%
  \begin{beamercolorbox}[wd=0.65\textwidth,sep=10pt,leftskip=8mm]{title}% % updated width - @eliainnocenti
  
    \vspace{0.5cm} % added - @eliainnocenti
  
    {\usebeamerfont{title}\inserttitle}
    
    \vspace{0.1cm} % added - @eliainnocenti
  
    {\usebeamerfont{subtitle}\insertsubtitle}

    {\usebeamerfont{subtitle}\@courseLabel}
    
    \vspace{0.3cm} % added - @eliainnocenti
    
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\textbf{\insertauthor} \ifdefempty{\@IDnumber}{}{(\@IDnumber)}}
  
    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate}
  \end{beamercolorbox}
}

% Define slide splitting dimensions (e.g. title and chapter slides)
\newcommand{\apograph@splitbackground}[1]{%
  \rule{0.56\paperwidth}{0pt}%
  \begin{tikzpicture}
    \clip (-0.1\paperwidth,-0.5\paperheight) -- 
          ( 0.5\paperwidth,-0.5\paperheight) -- 
          ( 0.5\paperwidth, 0.5\paperheight) -- 
          ( 0.1\paperwidth, 0.5\paperheight) -- cycle; 
    \node at (0.2\paperwidth,0) {%
      \IfFileExists{#1.png}{%
        \includegraphics[height=\paperheight]{#1}%
      }{%
        \tikz \node[draw=maincolor!35, fill=sintefgrey, minimum width=0.5\paperwidth, minimum height=\paperheight, align=center, font=\tiny\sffamily\color{maincolor!70}] {Optional\\background};
      }%
    };
  \end{tikzpicture}
}

\newbool{apograph@splittitle}
\newcommand{\apograph@titlebackground}{}
\newcommand{\apographTitleBackground}{%
  \@ifstar{\apograph@splitbackgroundchoice}{\apograph@fullbackgroundchoice}%
}
\newcommand{\apograph@fullbackgroundchoice}[1]{%
  \boolfalse{apograph@splittitle}%
  \renewcommand{\apograph@titlebackground}{#1}%
}
\newcommand{\apograph@splitbackgroundchoice}[1]{%
  \booltrue{apograph@splittitle}%
  \renewcommand{\apograph@titlebackground}{#1}%
}

% Overwrite the maketitle command for the title page
\renewcommand{\maketitle}{
\begingroup
  \ifdefempty{\apograph@titlebackground}{}{% Skip if no image is configured
    \setbeamertemplate{background}{%
      \ifbool{apograph@splittitle}{%
        \apograph@splitbackground{\apograph@titlebackground}%
      }{% Normal, full-screen background
        \IfFileExists{\apograph@titlebackground.png}{%
          \includegraphics[height=\paperheight]{\apograph@titlebackground}%
        }{}% Missing optional full background: keep the normal plain canvas.
      }%
    }%
  }
  \begin{frame}[plain,noframenumbering]%
  \titlepage%
  \end{frame}%
\endgroup
}

\newenvironment{apographwithoutheadline}{%
    \setbeamertemplate{headline}[default]
    \def\beamer@entrycode{\vspace*{-\headheight}}
}{}

% Define chapter environment
\newenvironment{apographchapter}[3][]{% Args: image (optional), color, frame title
  \begingroup
  \apographThemeColor{main}
  \setbeamertemplate{footline}{}
  \ifstrempty{#2}{
    \setbeamercolor{frametitle}{fg=white}
    \setbeamercolor{normal text}{fg=white,bg=maincolor}
  }{
    \setbeamercolor{frametitle}{fg=white}
    \setbeamercolor{normal text}{fg=white,bg=#2}
  }
  \ifstrempty{#1}{}{\setbeamertemplate{background}{\apograph@splitbackground{#1}}}
  \setbeamertemplate{frametitle}{%
    \vspace*{8ex}
    \begin{beamercolorbox}[wd=0.45\textwidth]{frametitle}
      \usebeamerfont{frametitle}\insertframetitle\\
      \usebeamerfont{framesubtitle}\insertframesubtitle
    \end{beamercolorbox}
  }
  \begin{frame}{#3}
  \hspace*{0.05\textwidth}%
  \minipage{0.35\textwidth}%
  \usebeamercolor[fg]{normal text}%
}{%
  \endminipage
  \end{frame}
  \endgroup
}

% Define sidepic environment
\newenvironment{apographsidepic}[2]{% Args: image, frame title
  \begingroup
  \setbeamertemplate{background}{%
  \hspace*{0.6\paperwidth}%
  \IfFileExists{#1.png}{%
    \includegraphics[height=\paperheight]{#1}%
  }{%
    \tikz \node[draw=maincolor!50, fill=sintefgrey, minimum width=0.4\paperwidth, minimum height=\paperheight, align=center, font=\tiny\sffamily\color{maincolor}] {Side Image\\Placeholder};
  }%
  }
  \setbeamertemplate{frametitle}{% Same as normal, but with right skip
    \vspace*{-3.5ex}
    \begin{beamercolorbox}[leftskip=2cm,rightskip=0.4\textwidth]{frametitle}%
      \usebeamerfont{frametitle}\insertframetitle\\
      \usebeamerfont{framesubtitle}\insertframesubtitle
    \end{beamercolorbox}
  }
  \begin{frame}{#2}
  \minipage{0.6\textwidth}%
}{%
  \endminipage
  \end{frame}
  \endgroup
}

% Define backmatter
\newcommand{\apographClosingMessage}{Thank you for listening!}
\newcommand{\apographSetClosingMessage}[1]{\renewcommand{\apographClosingMessage}{#1}}
\newcommand{\apographBackmatter}[1][]{
\begingroup
  \apographThemeColor{main}
  \begin{frame}[c,noframenumbering]
    \centering
    \begin{minipage}{\textwidth}
      \usebeamercolor[fg]{normal text}
      \centering
      \ifstrequal{#1}{notitle}{}{
        {\Huge \inserttitle\par}
        \vspace{5mm}
      }
      {\Large \textsl{\apographClosingMessage}\par}
      
      \ifx\@email\@empty
      \else
        \vspace{2mm}
        {\small \href{mailto:\@email}{\@email}}
      \fi
    \end{minipage}
  \end{frame}
\endgroup
}

% Define sectioning and table of contents
\AtBeginSection[]
{
    \iftoggle{apograph@sectionpages}{%
      \begingroup
      \apographThemeColor{main}
      \begin{frame}{Contents}
          \tableofcontents[currentsection]
      \end{frame}
      \endgroup
    }{}
}

% style of section presented in the table of contents
\setbeamertemplate{section in toc}{$\blacktriangleright$~\inserttocsection}

% Optionally automate the subtitle of each frame.
\iftoggle{apograph@autoframesubtitles}{%
  \pretocmd\beamer@checkframetitle{\framesubtitle{\thesection \, \secname}}{}{}%
}{}

% avoid numbering of frames that are breaked into multiply slides
\setbeamertemplate{frametitle continuation}{}
