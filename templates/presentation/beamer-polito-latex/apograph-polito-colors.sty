\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apograph-polito-colors}[2026/07/12 v0.2.0 unofficial PoliTo palette]

\RequirePackage{xcolor}

% Primary unofficial PoliTo-inspired palette. These values are not a statement
% of current brand compliance; see NOTICE and the catalog relationship field.
\definecolor{apographpolito-primary}{RGB/cmyk}{0,53,118/100,55,0,54}
\colorlet{maincolor}{apographpolito-primary}

% "Warm grey"
\definecolor{apographpolito-light}{RGB/cmyk}{235,235,230/0,0,0,.1}
\colorlet{sintefgrey}{apographpolito-light}
\colorlet{sintefgray}{apographpolito-light}

% Greens
\definecolorset{RGB/cmyk}{sintef}{}{lightgreen, 205,250,225/.23, 0,.20, 0;%
                                    green,       20,185,120/.73, 0,.67, 0;%
                                    darkgreen,    0, 70, 40/.93,.43,.92,.52}

% Additional colours
\definecolorset{RGB/cmyk}{sintef}{}{yellow, 200,155,20/20, 36,98, 8;%
                                    red,    190, 60,55/19, 86,77, 8;%
                                    lilla,  120,  0,80/48,100,27,31}

% Deprecated colours for backward compatibility
\definecolorset{HTML}{sintef}{}{cyan,      22A7E5;%
                                magenta,   EC008C;%
                                lightgrey, D8D0C7}
\colorlet{sinteflightgray}{sinteflightgrey}

% Stable Apograph names for new documents. The inherited sintef* aliases remain
% available so adapted showcase material continues to compile.
\colorlet{apographpolito-lightgreen}{sinteflightgreen}
\colorlet{apographpolito-green}{sintefgreen}
\colorlet{apographpolito-darkgreen}{sintefdarkgreen}
\colorlet{apographpolito-yellow}{sintefyellow}
\colorlet{apographpolito-red}{sintefred}
\colorlet{apographpolito-purple}{sinteflilla}
