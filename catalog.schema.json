{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eliainnocenti/apograph/catalog.schema.json",
  "title": "Apograph template catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "release_version", "repository", "templates"],
  "properties": {
    "$schema": {"const": "./catalog.schema.json"},
    "schema_version": {"$ref": "#/$defs/semver"},
    "release_version": {"$ref": "#/$defs/semver"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "description", "maintainer", "tooling_license"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "description": {"type": "string", "minLength": 1},
        "maintainer": {"type": "string", "minLength": 1},
        "tooling_license": {"type": "string", "minLength": 1}
      }
    },
    "templates": {
      "type": "array",
      "items": {"$ref": "#/$defs/template"}
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "nullableUri": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "nullableDate": {
      "type": ["string", "null"],
      "format": "date"
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression", "status", "notes"],
      "properties": {
        "expression": {"type": ["string", "null"], "minLength": 1},
        "status": {"enum": ["declared", "review-required", "verified"]},
        "notes": {"type": "string"}
      }
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "include_in_artifact", "preview"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "role": {"enum": ["starter", "showcase", "companion", "test"]},
        "include_in_artifact": {"type": "boolean"},
        "preview": {"type": "boolean"}
      }
    },
    "institution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "relationship", "requirements_url", "last_verified"],
      "properties": {
        "id": {"$ref": "#/$defs/slug"},
        "name": {"type": "string", "minLength": 1},
        "relationship": {"enum": ["generic", "unofficial", "endorsed", "official"]},
        "requirements_url": {"$ref": "#/$defs/nullableUri"},
        "last_verified": {"$ref": "#/$defs/nullableDate"}
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["texlive", "overleaf"],
      "properties": {
        "texlive": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "overleaf": {"enum": ["untested", "compatible", "incompatible", "not-applicable"]}
      }
    },
    "upstreamSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "authors", "revision", "license"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "authors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "revision": {"type": ["string", "null"]},
        "license": {"type": ["string", "null"]}
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sources", "notes"],
      "properties": {
        "kind": {"enum": ["original", "adapted", "redistributed"]},
        "sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/upstreamSource"}
        },
        "notes": {"type": "string"}
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "local_path", "mode", "required", "source_url", "sha256", "fallback", "license"],
      "properties": {
        "id": {"$ref": "#/$defs/slug"},
        "description": {"type": "string", "minLength": 1},
        "local_path": {"type": "string", "minLength": 1},
        "mode": {"enum": ["bundled", "fetched", "user-provided", "generated", "placeholder"]},
        "required": {"type": "boolean"},
        "source_url": {"$ref": "#/$defs/nullableUri"},
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "fallback": {"type": ["string", "null"]},
        "license": {"$ref": "#/$defs/license"}
      }
    },
    "maintainer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "github"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "github": {"type": ["string", "null"]}
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "name", "description", "purpose", "variant", "format", "status",
        "institution", "compiler", "compatibility", "source_dir", "entrypoints",
        "shared_deps", "license", "upstream", "assets", "tags", "maintainers",
        "readiness_notes", "created", "updated"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/slug"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "purpose": {"enum": ["thesis", "presentation", "report", "cv", "letter", "other"]},
        "variant": {"$ref": "#/$defs/slug"},
        "format": {"enum": ["latex", "typst"]},
        "status": {"enum": ["draft", "beta", "stable", "deprecated"]},
        "institution": {"$ref": "#/$defs/institution"},
        "compiler": {"enum": ["pdflatex", "lualatex", "xelatex", "typst"]},
        "compatibility": {"$ref": "#/$defs/compatibility"},
        "source_dir": {"type": "string", "minLength": 1},
        "entrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/entrypoint"}
        },
        "shared_deps": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "license": {"$ref": "#/$defs/license"},
        "upstream": {"$ref": "#/$defs/upstream"},
        "assets": {
          "type": "array",
          "items": {"$ref": "#/$defs/asset"}
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/slug"}
        },
        "maintainers": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/maintainer"}
        },
        "readiness_notes": {"type": "string"},
        "created": {"type": "string", "format": "date"},
        "updated": {"type": "string", "format": "date"}
      }
    }
  }
}
