\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apograph-typography}[2026/07/12 v0.2.0 Apograph typography primitives]

\RequirePackage{iftex}

% Legacy encodings apply only to pdfLaTeX. LuaLaTeX and XeLaTeX use Unicode
% natively and should select fonts in the consuming template.
\ifPDFTeX
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
\fi

% Microtype is a reusable rendering primitive. Link colors, spacing, captions,
% headers, table packages, and page layout are template policy and deliberately
% remain outside this shared module.
\RequirePackage{microtype}

\endinput
