\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apograph-math}[2026/06/12 v0.1.0 Apograph math utilities]

% --- Core math packages ---
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{mathtools}      % extends amsmath: \coloneqq, \DeclarePairedDelimiter, etc.
\RequirePackage{bm}             % bold math symbols via \bm{}

% --- Theorem-like environments ---
% Usage: \begin{theorem} ... \end{theorem}
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[chapter]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

