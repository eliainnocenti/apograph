% ============================================================================
% apograph-unifi.sty — Università di Firenze branding
% Part of the Apograph template collection
% https://github.com/eliainnocenti/apograph
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apograph-unifi}[2026/06/12 v0.1.0 Apograph UniFi branding]

\RequirePackage{apograph-colors}  % base color infrastructure
\RequirePackage{graphicx}         % \includegraphics

% --- UniFi official colors ---
% Source: Università di Firenze brand guidelines
\definecolor{unifi-red}{HTML}{8B0000}            % primary institutional red
\definecolor{unifi-darkred}{HTML}{6B0000}        % darker variant
\definecolor{unifi-gold}{HTML}{C5A55A}           % gold accent
\definecolor{unifi-grey}{HTML}{4D4D4D}           % body text grey
\definecolor{unifi-lightgrey}{HTML}{F0EDED}      % background

% Override the generic institution color aliases
\colorlet{apo-inst-primary}{unifi-red}
\colorlet{apo-inst-secondary}{unifi-gold}

% The logo file (theme/assets/unifi-logo.pdf) is user-provided until
% redistribution and trademark terms have been verified. It is not committed
% to the repository.
%
% If the file is missing, a placeholder box is rendered instead —
% compilation never fails.
%
% Usage in your template:
%   \unifilogo                     → default height (1.5cm)
%   \unifilogo[height=2cm]         → custom height
%   \unifilogo[width=5cm]          → custom width
%
\newcommand{\unifilogo}[1][height=1.5cm]{%
  \IfFileExists{theme/assets/unifi-logo.pdf}{%
    \includegraphics[#1]{theme/assets/unifi-logo.pdf}%
  }{%
    \fcolorbox{unifi-red}{unifi-lightgrey}{%
      \parbox[c][1.5cm][c]{4cm}{%
        \centering\small\sffamily\color{unifi-red}%
        {\bfseries Universit\`a di Firenze}\\[2pt]%
        {\scriptsize Logo placeholder}\\[1pt]%
        {\tiny Add theme/assets/unifi-logo.pdf}%
      }%
    }%
  }%
}

\endinput
