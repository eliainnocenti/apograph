% ============================================================================
% apograph-polito.sty — Unofficial Politecnico di Torino helpers
% Part of the Apograph template collection
% https://github.com/eliainnocenti/apograph
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apograph-polito}[2026/07/12 v0.2.0 Unofficial Apograph PoliTo helpers]

\RequirePackage{apograph-colors}  % base color infrastructure
\RequirePackage{graphicx}         % \includegraphics

% --- Unverified working palette ---
% These values are retained for draft compatibility. They must not be described
% as current official brand values until requirements evidence is recorded.
\definecolor{polito-blue}{HTML}{003576}         % primary institutional blue
\definecolor{polito-darkblue}{HTML}{002855}     % darker variant
\definecolor{polito-lightblue}{HTML}{4A90D9}    % lighter accent
\definecolor{polito-grey}{HTML}{4D4D4D}         % body text grey
\definecolor{polito-lightgrey}{HTML}{E6E6E6}    % background grey

% Override the generic institution color aliases
\colorlet{apo-inst-primary}{polito-blue}
\colorlet{apo-inst-secondary}{polito-lightblue}

% The logo file (theme/assets/polito-logo.pdf) is user-provided until
% redistribution and trademark terms have been verified. It is not committed
% to the repository.
%
% If the file is missing, a placeholder box is rendered instead —
% compilation never fails.
%
% Usage in your template:
%   \politologo                     → default height (1.5cm)
%   \politologo[height=2cm]         → custom height
%   \politologo[width=5cm]          → custom width
%
\newcommand{\politologo}[1][height=1.5cm]{%
  \IfFileExists{theme/assets/polito-logo.pdf}{%
    \includegraphics[#1]{theme/assets/polito-logo.pdf}%
  }{%
    \fcolorbox{polito-blue}{polito-lightgrey}{%
      \parbox[c][1.5cm][c]{4cm}{%
        \centering\small\sffamily\color{polito-blue}%
        {\bfseries Politecnico di Torino}\\[2pt]%
        {\scriptsize Logo placeholder}\\[1pt]%
        {\tiny Add theme/assets/polito-logo.pdf}%
      }%
    }%
  }%
}

\endinput
