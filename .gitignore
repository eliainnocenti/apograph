# =============================================================================
# Apograph — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# LaTeX auxiliary files
# Generated during compilation; never commit these.
# -----------------------------------------------------------------------------
*.aux
*.log
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)

# Compilation output directories
out/
**/out/

# BibTeX / BibLaTeX
*.bbl
*.blg
*.bcf
*.run.xml

# Glossaries
*.glo
*.gls
*.glg
*.ist

# Index
*.idx
*.ilg
*.ind

# Hyperref / bookmarks
*.out

# Beamer auxiliary files
*.nav
*.snm
*.vrb

# Miscellaneous LaTeX
*.dvi
*.ps
*.eps_tex
*.xdv
*.maf
*.mtc*
*.ptc
*-blx.bib

# latexmk generated
*.latexmain

# -----------------------------------------------------------------------------
# Typst build output
# Typst compiles to PDF; we track preview.pdf explicitly.
# -----------------------------------------------------------------------------
# (Typst doesn't generate aux files — just the output PDF)

# -----------------------------------------------------------------------------
# Generated PDFs
# We do NOT track compiled PDFs, EXCEPT for:
#   - preview.pdf files (committed for the catalog)
#   - asset PDFs in assets/ directories (logos, diagrams)
# -----------------------------------------------------------------------------
*.pdf
!**/preview.pdf
!**/assets/**/*.pdf

# -----------------------------------------------------------------------------
# Build output (generated by pack.py and preview.py)
# -----------------------------------------------------------------------------
build/
dist/
*.zip

# -----------------------------------------------------------------------------
# Python
# Used by scripts/ and cli/ (Phase 2)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
venv/
.env

# -----------------------------------------------------------------------------
# OS-specific files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# -----------------------------------------------------------------------------
# Editor / IDE files
# Note: .vscode/ is committed intentionally (settings.json, extensions.json)
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*.swn
*.bak
*.orig
\#*\#

# -----------------------------------------------------------------------------
# Temporary / scratch
# The tmp/ directory is for local scratch work..
# -----------------------------------------------------------------------------
tmp/
tmp.md
tmp.txt
